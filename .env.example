# ============================================
# SHOPYSH - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://shopysh:YOUR_DB_PASSWORD@db:5433/shopysh?schema=public
DB_PASSWORD=YOUR_DB_PASSWORD

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://www.shopysh.com

# Domain
DOMAIN=www.shopysh.com

# ---- AI / LLM Configuration ----
# Default: Local Qwen2.5 3B Instruct (Q4_K_M) via llama.cpp (no API key needed!)
# The local LLM runs as a Docker service alongside the app.
# To use an external provider instead, uncomment and set:
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# CPU threads for local LLM inference (set to your VPS CPU core count)
LLM_THREADS=4

# ---- Email (SMTP) ----
# Required for campaign emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@shopysh.com

# ---- Google SSO (Optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Cloud Storage (Optional) ----
# For file uploads (product images, etc.)
AWS_REGION=
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- WhatsApp Integration (Optional) ----
WHATSAPP_VERIFY_TOKEN=

# ---- Google Analytics (Optional) ----
NEXT_PUBLIC_GA_MEASUREMENT_ID=
