// ========================================
// 15. ACCOUNTING ENGINE (Finance Module v2)
// ========================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE

  @@map("account_type")
}

enum JournalEntryType {
  SALES_INVOICE
  SALES_RECEIPT
  SALES_RETURN
  CREDIT_NOTE
  PURCHASE_INVOICE
  PURCHASE_PAYMENT
  PURCHASE_RETURN
  DEBIT_NOTE
  CASH_RECEIPT
  CASH_PAYMENT
  BANK_DEPOSIT
  BANK_WITHDRAWAL
  BANK_TRANSFER
  INVENTORY_ADJUSTMENT
  ASSET_PURCHASE
  ASSET_DISPOSAL
  DEPRECIATION
  EXPENSE_CLAIM
  TAX_PAYMENT
  OPENING_BALANCE
  CLOSING_ENTRY
  GENERAL_JOURNAL

  @@map("journal_entry_type")
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  REVERSED
  CANCELLED

  @@map("journal_status")
}

enum FiscalYearStatus {
  OPEN
  CLOSING
  CLOSED

  @@map("fiscal_year_status")
}

enum PeriodStatus {
  OPEN
  CLOSED

  @@map("period_status")
}

model GlAccount {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  code            String      @db.VarChar(20)
  name            String      @db.VarChar(255)
  accountType     AccountType @map("account_type")
  accountSubtype  String?     @map("account_subtype") @db.VarChar(100)
  parentId        String?     @map("parent_id") @db.Uuid
  level           Int         @default(1)
  isActive        Boolean     @default(true) @map("is_active")
  allowPosting    Boolean     @default(true) @map("allow_posting")
  description     String?     @db.Text
  currency        String      @default("NGN") @db.VarChar(3)
  openingBalance  Decimal     @default(0) @map("opening_balance") @db.Decimal(18, 2)
  isSystemAccount Boolean     @default(false) @map("is_system_account")
  systemTag       String?     @map("system_tag") @db.VarChar(50)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant       Tenant        @relation("GlAccountTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  parent       GlAccount?    @relation("GlAccountHierarchy", fields: [parentId], references: [id])
  children     GlAccount[]   @relation("GlAccountHierarchy")
  journalLines JournalLine[]

  @@unique([tenantId, code], map: "idx_gl_accounts_code_tenant")
  @@index([tenantId, accountType], map: "idx_gl_accounts_type")
  @@index([tenantId, parentId], map: "idx_gl_accounts_parent")
  @@index([tenantId, isSystemAccount], map: "idx_gl_accounts_system")
  @@map("gl_accounts")
}

model FiscalYear {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  name      String           @db.VarChar(100)
  startDate DateTime         @map("start_date") @db.Date
  endDate   DateTime         @map("end_date") @db.Date
  status    FiscalYearStatus @default(OPEN)
  isDefault Boolean          @default(false) @map("is_default")
  createdAt DateTime         @default(now()) @map("created_at")

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periods AccountingPeriod[]
  budgets Budget[]

  @@unique([tenantId, name], map: "idx_fiscal_years_name")
  @@index([tenantId, status], map: "idx_fiscal_years_status")
  @@map("fiscal_years")
}

model AccountingPeriod {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  fiscalYearId String       @map("fiscal_year_id") @db.Uuid
  periodNumber Int          @map("period_number")
  name         String       @db.VarChar(50)
  startDate    DateTime     @map("start_date") @db.Date
  endDate      DateTime     @map("end_date") @db.Date
  status       PeriodStatus @default(OPEN)
  createdAt    DateTime     @default(now()) @map("created_at")

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalYear FiscalYear     @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  journals   JournalEntry[]

  @@unique([fiscalYearId, periodNumber], map: "idx_periods_fy_number")
  @@index([tenantId, status], map: "idx_periods_status")
  @@map("accounting_periods")
}

model JournalEntry {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  entryNumber String           @map("entry_number") @db.VarChar(30)
  periodId    String?          @map("period_id") @db.Uuid
  entryDate   DateTime         @map("entry_date") @db.Date
  postingDate DateTime?        @map("posting_date") @db.Date
  description String           @db.VarChar(500)
  reference   String?          @db.VarChar(100)
  entryType   JournalEntryType @map("entry_type")
  status      JournalStatus    @default(DRAFT)
  sourceType  String?          @map("source_type") @db.VarChar(50)
  sourceId    String?          @map("source_id") @db.Uuid

  isReversal           Boolean  @default(false) @map("is_reversal")
  reversesEntryId      String?  @map("reverses_entry_id") @db.Uuid
  reversedByEntryId    String?  @map("reversed_by_entry_id") @db.Uuid
  recurringJournalId   String?  @map("recurring_journal_id") @db.Uuid

  currency     String    @default("NGN") @db.VarChar(3)
  exchangeRate Decimal   @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  totalDebit   Decimal   @default(0) @map("total_debit") @db.Decimal(18, 2)
  totalCredit  Decimal   @default(0) @map("total_credit") @db.Decimal(18, 2)

  notes       String?   @db.Text
  postedById  String?   @map("posted_by_id") @db.Uuid
  postedAt    DateTime? @map("posted_at")
  createdById String?   @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period           AccountingPeriod?  @relation(fields: [periodId], references: [id])
  lines            JournalLine[]
  recurringJournal RecurringJournal?  @relation(fields: [recurringJournalId], references: [id])

  @@unique([tenantId, entryNumber], map: "idx_journal_entry_number")
  @@index([tenantId, entryDate(sort: Desc)], map: "idx_journal_date")
  @@index([tenantId, status], map: "idx_journal_status")
  @@index([tenantId, entryType], map: "idx_journal_type")
  @@index([sourceType, sourceId], map: "idx_journal_source")
  @@map("journal_entries")
}

model JournalLine {
