model RecurringJournal {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  frequency       String    @db.VarChar(20)   // daily | weekly | monthly | quarterly | yearly
  dayOfMonth      Int?      @map("day_of_month")
  entryType       String    @default("GENERAL_JOURNAL") @map("entry_type") @db.VarChar(50)
  currency        String    @default("NGN") @db.VarChar(3)
  isActive        Boolean   @default(true) @map("is_active")
  nextRunDate     DateTime  @map("next_run_date") @db.Date
  lastRunDate     DateTime? @map("last_run_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  runCount        Int       @default(0) @map("run_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines   RecurringJournalLine[]
  runs    JournalEntry[]

  @@index([tenantId, isActive, nextRunDate], map: "idx_recurring_journals")
  @@map("recurring_journals")
}

model RecurringJournalLine {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recurringJournalId String  @map("recurring_journal_id") @db.Uuid
  accountId          String  @map("account_id") @db.Uuid
  debit              Decimal @default(0) @db.Decimal(18, 2)
  credit             Decimal @default(0) @db.Decimal(18, 2)
  description        String? @db.VarChar(255)

  recurringJournal RecurringJournal @relation(fields: [recurringJournalId], references: [id], onDelete: Cascade)

  @@index([recurringJournalId], map: "idx_recurring_journal_lines")
  @@map("recurring_journal_lines")
}

