model BankStatement {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  bankAccountId String?   @map("bank_account_id") @db.Uuid
  statementDate DateTime  @map("statement_date") @db.Date
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(18, 2)
  closingBalance Decimal  @default(0) @map("closing_balance") @db.Decimal(18, 2)
  currency      String    @default("NGN") @db.VarChar(3)
  importedAt    DateTime  @default(now()) @map("imported_at")
  status        String    @default("pending") @db.VarChar(20) // pending | reconciled

  tenant  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines   BankStatementLine[]

  @@index([tenantId, statementDate], map: "idx_bank_statements")
  @@map("bank_statements")
}

model BankStatementLine {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  statementId     String    @map("statement_id") @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  transactionDate DateTime  @map("transaction_date") @db.Date
  description     String    @db.VarChar(500)
  debit           Decimal   @default(0) @db.Decimal(18, 2)
  credit          Decimal   @default(0) @db.Decimal(18, 2)
  balance         Decimal?  @db.Decimal(18, 2)
  reference       String?   @db.VarChar(255)
  matchedEntryId  String?   @map("matched_entry_id") @db.Uuid  // FK to JournalEntry
  isMatched       Boolean   @default(false) @map("is_matched")
  isIgnored       Boolean   @default(false) @map("is_ignored")

  statement BankStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId], map: "idx_bank_statement_lines")
  @@index([tenantId, isMatched], map: "idx_bank_statement_lines_matched")
  @@map("bank_statement_lines")
}
