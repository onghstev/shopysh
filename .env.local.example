# ============================================
# SHOPYSH — LOCAL development environment
# Copy to .env.local and adjust if needed:  cp .env.local.example .env.local
# Used by docker-compose.local.yml
# ============================================

# Local Postgres password (any value; only used by your local DB container)
DB_PASSWORD=shopysh_local

# NextAuth — generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=local_dev_secret_change_me
# Match the URL you actually open in the browser (nginx front door)
NEXTAUTH_URL=http://localhost:8088

# CPU threads for the local LLM (set to your laptop's core count)
LLM_THREADS=4

# ---- Optional ----
# SMTP (campaign emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google SSO — add http://localhost:8088/api/auth/callback/google as an
# authorized redirect URI in Google Cloud Console to test it locally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
